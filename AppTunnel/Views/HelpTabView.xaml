<UserControl x:Class="AppTunnel.Views.HelpTabView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:services="clr-namespace:AppTunnel.Services">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Padding="0,14,0,12">
        <StackPanel Margin="16,0">

            <!-- Overview -->
            <Border Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="TunnelX"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Split tunneling ШЁШұШ§ЫҢ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ШҢ Щ…ЩӮШөШҜЩҮШ§ ЩҲ ШӯШ§Щ„ШӘ Ъ©Щ„ ШіЫҢШіШӘЩ…"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="#1AE8803A"
                            CornerRadius="8"
                            Padding="10,5"
                            VerticalAlignment="Center">
                        <TextBlock Text="{x:Static services:AppInfo.VersionText}"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   FlowDirection="LeftToRight"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Project + Support -->
            <Border Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="ЩҫШұЩҲЪҳЩҮ ШўШІШ§ШҜ ЩҲ ШӯЩ…Ш§ЫҢШӘ"/>
                        <TextBlock Text="{Binding AppCreatorText}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding AppGitHubUrl}"
                                   FontSize="10"
                                   Foreground="{StaticResource AccentBrush}"
                                   FlowDirection="LeftToRight"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding AppLicenseText, StringFormat=Щ„Ш§ЫҢШіЩҶШі: {0}}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FlowDirection="LeftToRight"
                                   Margin="0,5,0,0"/>
                        <TextBlock Text="{Binding DonatePayPalText}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FlowDirection="LeftToRight"
                                   Margin="0,5,0,0"/>
                        <TextBlock Text="{Binding CryptoDonationText}"
                                   FontSize="10"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="Consolas"
                                   FlowDirection="LeftToRight"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                MinWidth="150">
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="ШЁШ§ШІ Ъ©ШұШҜЩҶ ЪҜЫҢШӘвҖҢЩҮШ§ШЁ"
                                Command="{Binding OpenGitHubCommand}"
                                Padding="14,8"/>
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="ШӯЩ…Ш§ЫҢШӘ ШЁШ§ ЩҫЫҢвҖҢЩҫЩ„"
                                Command="{Binding OpenDonateCommand}"
                                Padding="16,8"
                                Margin="0,8,0,0"/>
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="Ъ©ЩҫЫҢ Ш§Ш·Щ„Ш§Ш№Ш§ШӘ ШӯЩ…Ш§ЫҢШӘ"
                                Command="{Binding CopyDonationInfoCommand}"
                                Padding="14,8"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Updates -->
            <Border Style="{StaticResource CardPanel}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource SectionHeader}" Text="ШЁШұЩҲШІШұШіШ§ЩҶЫҢ"/>
                        <TextBlock Text="{Binding UpdateStatusText}"
                                   FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   LineHeight="18"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Vertical"
                                VerticalAlignment="Center"
                                MinWidth="150">
                        <Button Style="{StaticResource SecondaryButton}"
                                Content="{Binding UpdateButtonText}"
                                Command="{Binding CheckForUpdatesCommand}"
                                Padding="14,8"/>
                        <Button Style="{StaticResource PrimaryButton}"
                                Content="ШЁШ§ШІ Ъ©ШұШҜЩҶ ШөЩҒШӯЩҮ Ш§ЩҶШӘШҙШ§Шұ"
                                Command="{Binding OpenLatestReleaseCommand}"
                                Padding="14,8"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Quick Path -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="ШҙШұЩҲШ№ ШіШұЫҢШ№"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Background="#11FFFFFF" CornerRadius="8" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="Ыұ. ЩҫШұЩҲЩҒШ§ЫҢЩ„" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="ЩҶЩҲШ№ Ш§ШӘШөШ§Щ„ ШұШ§ Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ: L2TPШҢ V2Ray/Xray ЫҢШ§ Ш§ЩҲЩҫЩҶвҖҢЩҲЫҢвҖҢЩҫЫҢвҖҢШ§ЩҶ. ШЁШұШ§ЫҢ Ш§ШіЩҫЩ„ЫҢШӘ Ш§ЩҲЩҫЩҶвҖҢЩҲЫҢвҖҢЩҫЫҢвҖҢШ§ЩҶШҢ ЩҶШіШ®ЩҮ Community Щ„Ш§ШІЩ… Ш§ШіШӘШӣ ЩҒШ§ЫҢЩ„ .ovpn ШұШ§ Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ ЩҲ ЩҶШ§Щ… Ъ©Ш§ШұШЁШұЫҢ/ШұЩ…ШІ ШұШ§ ШҜШұ TunnelX ЩҲШ§ШұШҜ Ъ©ЩҶЫҢШҜ."
                                           FontSize="10" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" Background="#11FFFFFF" CornerRadius="8" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="ЫІ. ШӘШіШӘ ШіШұЩҲШұ" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="ЩӮШЁЩ„ Ш§ШІ Ш§ШӘШөШ§Щ„ШҢ ШӘШіШӘ ШіШұЩҲШұ ШұШ§ ШЁШІЩҶЫҢШҜ. ШЁШұШ§ЫҢ TLSШҢ handshake ЩҲШ§ЩӮШ№ЫҢ Ш§ЩҶШҜШ§ШІЩҮвҖҢЪҜЫҢШұЫҢ Щ…ЫҢвҖҢШҙЩҲШҜ."
                                           FontSize="10" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" Background="#11FFFFFF" CornerRadius="8" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="Ыі. ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ЫҢЫҢ Ъ©ЩҮ ШЁШ§ЫҢШҜ Ш§ШІ ШӘЩҲЩҶЩ„ Ш№ШЁЩҲШұ Ъ©ЩҶЩҶШҜ ШұШ§ ШҜШұ ШӘШЁ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ ЩҒШ№Ш§Щ„ Ъ©ЩҶЫҢШҜ."
                                           FontSize="10" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="2" Background="#11FFFFFF" CornerRadius="8" Padding="12,10">
                            <StackPanel>
                                <TextBlock Text="Ыҙ. Ш§ШӘШөШ§Щ„" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="ШЁШ№ШҜ Ш§ШІ Ш§ШӘШөШ§Щ„ШҢ Ъ©Ш§ШұШӘ ШіЩ„Ш§Щ…ШӘ ШӘШұШ§ЩҒЫҢЪ© ШұШ§ ШЁШұШ§ЫҢ LeakШҢ DNSШҢ IPv6 ЩҲ Route ШЁШұШұШіЫҢ Ъ©ЩҶЫҢШҜ."
                                           FontSize="10" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Connection Types -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Style="{StaticResource SectionHeader}" Text="ШұШ§ЩҮЩҶЩ…Ш§ЫҢ ЩҶЩҲШ№ Ш§ШӘШөШ§Щ„"/>
                    <TextBlock Text="L2TP/IPsec"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="ШўШҜШұШі ШіШұЩҲШұШҢ ЩҶШ§Щ… Ъ©Ш§ШұШЁШұЫҢШҢ ШұЩ…ШІ Ш№ШЁЩҲШұ ЩҲ Pre-Shared Key ШұШ§ ЩҲШ§ШұШҜ Ъ©ЩҶЫҢШҜШӣ TunnelX Ш§ШӘШөШ§Щ„ ЩҲЫҢЩҶШҜЩҲШІ ШұШ§ Ш§ЫҢШ¬Ш§ШҜ ЩҲ Щ…ШіЫҢШұЩҮШ§ ШұШ§ Щ…ШҜЫҢШұЫҢШӘ Щ…ЫҢвҖҢЪ©ЩҶШҜ."
                               FontSize="11"
                               LineHeight="18"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,10"/>

                    <TextBlock Text="V2Ray / Xray"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Щ„ЫҢЩҶЪ© ЫҢШ§ Ъ©Ш§ЩҶЩҒЫҢЪҜ V2Ray/Xray ШұШ§ ШҜШұ ЩҒЫҢЩ„ШҜ Ъ©Ш§ЩҶЩҒЫҢЪҜ ЩҲШ§ШұШҜ Ъ©ЩҶЫҢШҜ. TunnelX ШЁШ§ sing-box/Xray ШӘЩҲЩҶЩ„ ШұШ§ ШЁШ§Щ„Ш§ Щ…ЫҢвҖҢШўЩҲШұШҜ ЩҲ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ЫҢ Ш§ЩҶШӘШ®Ш§ШЁЫҢ ШұШ§ Ш§ШІ ШўЩҶ Ш№ШЁЩҲШұ Щ…ЫҢвҖҢШҜЩҮШҜ."
                               FontSize="11"
                               LineHeight="18"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,10"/>

                    <TextBlock Text="OpenVPN"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="TunnelX ЩҒШ§ЫҢЩ„ Ш§ЩҲЩҫЩҶвҖҢЩҲЫҢвҖҢЩҫЫҢвҖҢШ§ЩҶ ШұШ§ ЩҮЩ…ШұШ§ЩҮ Ш®ЩҲШҜ ШӘЩҲШІЫҢШ№ ЩҶЩ…ЫҢвҖҢЪ©ЩҶШҜ. ШЁШұШ§ЫҢ Ш§ШіЩҫЩ„ЫҢШӘвҖҢШӘШ§ЩҶЩ„ЫҢЩҶЪҜ ШЁШ§ЫҢШҜ ЩҶШіШ®ЩҮ Community ЩҶШөШЁ ШЁШ§ШҙШҜШҢ ЪҶЩҲЩҶ TunnelX ШЁШ§ЫҢШҜ ЩҒШ§ЫҢЩ„ openvpn.exe ШұШ§ ШЁШ§ Ъ©Ш§ЩҶЩҒЫҢЪҜ ШіШ§ШІЪҜШ§Шұ ШЁШ§ Ш§ШіЩҫЩ„ЫҢШӘ Ш§Ш¬ШұШ§ Ъ©ЩҶШҜ. ЩҶШіШ®ЩҮ Connect Щ…Ш№Щ…ЩҲЩ„Ш§ЩӢ Щ…ШіЫҢШұ ЩҲ DNS ШұШ§ Ш®ЩҲШҜШҙ ШӘШәЫҢЫҢШұ Щ…ЫҢвҖҢШҜЩҮШҜ ЩҲ ШЁШұШ§ЫҢ Ш¬ШҜШ§ Ъ©ШұШҜЩҶ ШӘШұШ§ЩҒЫҢЪ© ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ Щ…ЩҶШ§ШіШЁ ЩҶЫҢШіШӘ. ШҜШұ ШӘШЁ Ш§ШӘШөШ§Щ„ ЩҒШ§ЫҢЩ„ .ovpn ШұШ§ Ш§ЩҶШӘШ®Ш§ШЁ Ъ©ЩҶЫҢШҜ ЩҲ Ш§ЪҜШұ ШіШұЩҲШұ ЩҶЫҢШ§ШІ ШҜШ§ШұШҜШҢ ЩҶШ§Щ… Ъ©Ш§ШұШЁШұЫҢ ЩҲ ШұЩ…ШІ ШұШ§ ШҜШұ TunnelX ЩҲШ§ШұШҜ Ъ©ЩҶЫҢШҜ."
                               FontSize="11"
                               LineHeight="18"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <!-- Modes -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="ШӯШ§Щ„ШӘ Ш§ЩҶШӘШ®Ш§ШЁЫҢ"/>
                        <TextBlock Text="ЩҒЩӮШ· ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ЫҢ Ш§ЩҶШӘШ®Ш§ШЁвҖҢШҙШҜЩҮ ЩҲ Щ…ЩӮШөШҜЩҮШ§ЫҢ Щ„ШІЩҲЩ…ЫҢ Ш§ШІ ШӘЩҲЩҶЩ„ Ш№ШЁЩҲШұ Щ…ЫҢвҖҢЪ©ЩҶЩҶШҜ. Ш§ЫҢЩҶ ШӯШ§Щ„ШӘ ШЁШұШ§ЫҢ Щ…ШөШұЩҒ Ъ©Щ…ШӘШұ ЩҲ Ъ©ЩҶШӘШұЩ„ ШҜЩӮЫҢЩӮвҖҢШӘШұ ЩҫЫҢШҙЩҶЩҮШ§ШҜ Щ…ЫҢвҖҢШҙЩҲШҜ."
                                   FontSize="11"
                                   LineHeight="19"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="Ш№ШЁЩҲШұ Ъ©Щ„ ШіЫҢШіШӘЩ…"/>
                        <TextBlock Text="ЩҲЩӮШӘЫҢ Full Route ШұЩҲШҙЩҶ ШЁШ§ШҙШҜШҢ Ъ©Щ„ ШӘШұШ§ЩҒЫҢЪ© ЩҲЫҢЩҶШҜЩҲШІ Ш§ШІ ШӘЩҲЩҶЩ„ Ш№ШЁЩҲШұ Щ…ЫҢвҖҢЪ©ЩҶШҜ. ШЁШұШ§ЫҢ ШӘШіШӘ ЫҢШ§ ШІЩ…Ш§ЩҶЫҢ Ъ©ЩҮ ЩҮЩ…ЩҮ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ ШЁШ§ЫҢШҜ VPN ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙЩҶШҜ Щ…ЩҶШ§ШіШЁ Ш§ШіШӘ."
                                   FontSize="11"
                                   LineHeight="19"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Rules + Apps -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="19"
                                   Foreground="{StaticResource TextSecondaryBrush}">
ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ЫҢ Store/MSIX ЩҲ WebView2 Щ…Щ…Ъ©ЩҶ Ш§ШіШӘ ЪҶЩҶШҜ ЩҫШұШҜШ§ШІШҙ ШҜШ§ШҙШӘЩҮ ШЁШ§ШҙЩҶШҜ. Ш§ЪҜШұ Ш§ЩҫЫҢ ШҜЫҢШҜЩҮ ЩҶШҙШҜШҢ ШўЩҶ ШұШ§ ШЁШ§ШІ Ъ©ЩҶЫҢШҜ ЩҲ ШҜЩҲШЁШ§ШұЩҮ ШЁШ§ШұЪҜШ°Ш§ШұЫҢ ШЁШұЩҶШ§Щ…ЩҮвҖҢЩҮШ§ ШұШ§ ШЁШІЩҶЫҢШҜ.
                        </TextBlock>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="ЩӮЩҲШ§ЩҶЫҢЩҶ Щ…ШіЫҢШұ"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="19"
                                   Foreground="{StaticResource TextSecondaryBrush}">
Ш§ШіШӘШ«ЩҶШ§ЩҮШ§ Щ…ЩӮШөШҜ ШұШ§ Щ…ШіШӘЩӮЫҢЩ… ЩҶЪҜЩҮ Щ…ЫҢвҖҢШҜШ§ШұЩҶШҜ. Щ„ШІЩҲЩ…ЫҢвҖҢЩҮШ§ Щ…ЩӮШөШҜ ШұШ§ ШӯШӘЫҢ ШЁШҜЩҲЩҶ Ш§ЩҶШӘШ®Ш§ШЁ ШЁШұЩҶШ§Щ…ЩҮ Ш§ШІ ШӘЩҲЩҶЩ„ Ш№ШЁЩҲШұ Щ…ЫҢвҖҢШҜЩҮЩҶШҜ. ШҜШ§Щ…ЩҶЩҮШҢ IP ЩҲ URL ЩӮШ§ШЁЩ„ Ш§ШіШӘЩҒШ§ШҜЩҮ Ш§ШіШӘ.
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Local Proxy + Diagnostics -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeader}" Text="SOCKS5 ШҜШ§Ш®Щ„ЫҢ"/>
                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="19"
                                   Foreground="{StaticResource TextSecondaryBrush}">
